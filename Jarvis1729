// ================= CONVERSATION MEMORY =================
#define MAX_TURNS 4
struct Turn { String role; String content; };
Turn history[MAX_TURNS * 2];
int  histLen = 0;

void pushHistory(const String& role, const String& content) {
  if (histLen >= MAX_TURNS * 2) {
    for (int i = 0; i < (MAX_TURNS * 2 - 2); i++) history[i] = history[i + 2];
    histLen -= 2;
  }
  history[histLen].role = role;
  history[histLen].content = content;
  histLen++;
}

// ================= LED + MOTOR =================
void ledOn()  { digitalWrite(LED_PIN, HIGH); }
void ledOff() { digitalWrite(LED_PIN, LOW); }
void motorOn()  { digitalWrite(MOTOR_AIN1, HIGH); digitalWrite(MOTOR_AIN2, LOW); }
void motorOff() { digitalWrite(MOTOR_AIN1, LOW);  digitalWrite(MOTOR_AIN2, LOW); }
void buzz(uint16_t ms) { motorOn(); delay(ms); motorOff(); }
void ioInit() {
  pinMode(LED_PIN, OUTPUT); pinMode(MOTOR_AIN1, OUTPUT); pinMode(MOTOR_AIN2, OUTPUT);
  ledOff(); motorOff();
  Serial.println("[IO] LED + motor ready");
}

// ================= RESET REASON =================
void printResetReason() {
  esp_reset_reason_t r = esp_reset_reason();
  Serial.printf("[BOOT] reset reason = %d ", (int)r);
  switch (r) {
    case ESP_RST_POWERON:   Serial.println("(power-on, normal)"); break;
    case ESP_RST_SW:        Serial.println("(software reset)"); break;
    case ESP_RST_PANIC:     Serial.println("(PANIC / crash)"); break;
    case ESP_RST_INT_WDT:   Serial.println("(interrupt watchdog)"); break;
    case ESP_RST_TASK_WDT:  Serial.println("(task watchdog)"); break;
    case ESP_RST_WDT:       Serial.println("(other watchdog)"); break;
    case ESP_RST_BROWNOUT:  Serial.println("(BROWNOUT - power supply!)"); break;
    case ESP_RST_DEEPSLEEP: Serial.println("(deep sleep wake)"); break;
    default:                Serial.println("(unknown)"); break;
  }
}

// ================= I2S MIC =================
void micInit() {
  i2s_chan_config_t chan_cfg = I2S_CHANNEL_DEFAULT_CONFIG(I2S_NUM_0, I2S_ROLE_MASTER);
  i2s_new_channel(&chan_cfg, NULL, &mic_rx);
  i2s_std_config_t std_cfg = {
    .clk_cfg = I2S_STD_CLK_DEFAULT_CONFIG(SAMPLE_RATE),
    .slot_cfg = I2S_STD_PHILIPS_SLOT_DEFAULT_CONFIG(
                  I2S_DATA_BIT_WIDTH_32BIT, I2S_SLOT_MODE_MONO),
    .gpio_cfg = {
      .mclk = I2S_GPIO_UNUSED, .bclk = (gpio_num_t)MIC_SCK, .ws = (gpio_num_t)MIC_WS,
      .dout = I2S_GPIO_UNUSED, .din = (gpio_num_t)MIC_SD,
      .invert_flags = { .mclk_inv = false, .bclk_inv = false, .ws_inv = false },
    },
  };
  std_cfg.slot_cfg.slot_mask = I2S_STD_SLOT_LEFT;
  i2s_channel_init_std_mode(mic_rx, &std_cfg);
  i2s_channel_enable(mic_rx);
  Serial.println("[MIC] ready");
}

// ================= WAV HEADER =================
void writeWavHeader(uint8_t* b, uint32_t pcmLen) {
  uint32_t fileLen = pcmLen + 36, byteRate = SAMPLE_RATE * 2;
  memcpy(b, "RIFF", 4);
  b[4]=fileLen&0xFF; b[5]=(fileLen>>8)&0xFF; b[6]=(fileLen>>16)&0xFF; b[7]=(fileLen>>24)&0xFF;
  memcpy(b+8,"WAVEfmt ",8);
  b[16]=16;b[17]=0;b[18]=0;b[19]=0; b[20]=1;b[21]=0; b[22]=1;b[23]=0;
  b[24]=SAMPLE_RATE&0xFF;b[25]=(SAMPLE_RATE>>8)&0xFF;b[26]=(SAMPLE_RATE>>16)&0xFF;b[27]=(SAMPLE_RATE>>24)&0xFF;
  b[28]=byteRate&0xFF;b[29]=(byteRate>>8)&0xFF;b[30]=(byteRate>>16)&0xFF;b[31]=(byteRate>>24)&0xFF;
  b[32]=2;b[33]=0; b[34]=16;b[35]=0;
  memcpy(b+36,"data",4);
  b[40]=pcmLen&0xFF;b[41]=(pcmLen>>8)&0xFF;b[42]=(pcmLen>>16)&0xFF;b[43]=(pcmLen>>24)&0xFF;
}

// ================= RECORD =================
void recordAudio() {
  uint8_t* pcm = wavBuf + 44;
  size_t written = 0; int32_t raw[256]; size_t bytesRead; int32_t peak = 0;
  for (int w = 0; w < 8; w++) i2s_channel_read(mic_rx, raw, sizeof(raw), &bytesRead, pdMS_TO_TICKS(100));
  Serial.println("[REC] Speak NOW...");
  delay(200);
  uint32_t startMs = millis();
  while (written < PCM_BYTES) {
    if (millis() - startMs > (RECORD_SECS * 1000UL + 3000UL)) break;
    i2s_channel_read(mic_rx, raw, sizeof(raw), &bytesRead, pdMS_TO_TICKS(500));
    if (bytesRead == 0) continue;
    int samples = bytesRead / 4;
    for (int i = 0; i < samples && written < PCM_BYTES; i++) {
      int16_t s16 = (int16_t)(raw[i] >> GAIN_SHIFT);
      if (abs(s16) > peak) peak = abs(s16);
      pcm[written++] = s16 & 0xFF; pcm[written++] = (s16 >> 8) & 0xFF;
    }
  }
  writeWavHeader(wavBuf, (uint32_t)written);
  Serial.printf("[REC] %u bytes, peak=%d\n", (unsigned)written, (int)peak);
}

// ================= DEEPGRAM STT =================
String transcribe() {
  uint32_t pcmLen = (uint32_t)(wavBuf[40]) | ((uint32_t)wavBuf[41]<<8) |
                    ((uint32_t)wavBuf[42]<<16) | ((uint32_t)wavBuf[43]<<24);
  size_t sendLen = pcmLen + 44;
  Serial.printf("[STT] uploading %u bytes\n", (unsigned)sendLen);
  String result = "";
  for (int attempt = 1; attempt <= 4; attempt++) {
    WiFiClientSecure client; client.setInsecure(); client.setTimeout(HTTP_TIMEOUT_MS);
    HTTPClient https; https.setReuse(false); https.setTimeout(HTTP_TIMEOUT_MS);
    if (!https.begin(client, DG_HOST)) { delay(600); continue; }
    https.addHeader("Authorization", String("Token ") + DG_KEY);
    https.addHeader("Content-Type", "audio/wav");
    https.addHeader("Connection", "close");
    int code = https.POST(wavBuf, sendLen);
    Serial.printf("[STT] try %d HTTP %d\n", attempt, code);
    if (code == 200) {
      String payload = https.getString(); https.end();
      JsonDocument filter; filter["results"]["channels"][0]["alternatives"][0]["transcript"] = true;
      JsonDocument doc;
      DeserializationError err = deserializeJson(doc, payload, DeserializationOption::Filter(filter));
      if (err) { Serial.printf("[STT] JSON err: %s\n", err.c_str()); break; }
      result = doc["results"]["channels"][0]["alternatives"][0]["transcript"].as<String>();
      break;
    }
    https.end();
    delay(1000 * attempt);
  }
  return result;
}

// ================= GROQ BRAIN =================
String askGroq(const String& userText) {
  String answer = "";
  for (int attempt = 1; attempt <= 3; attempt++) {
    WiFiClientSecure client; client.setInsecure(); client.setTimeout(HTTP_TIMEOUT_MS);
    HTTPClient https; https.setReuse(false); https.setTimeout(HTTP_TIMEOUT_MS);
    JsonDocument req;
    req["model"] = GROQ_MODEL; req["temperature"] = 0.6; req["max_tokens"] = 500;
    JsonArray msgs = req["messages"].to<JsonArray>();
    JsonObject sys = msgs.add<JsonObject>(); sys["role"]="system"; sys["content"]=SYSTEM_PROMPT;
    for (int i = 0; i < histLen; i++) {
      JsonObject m = msgs.add<JsonObject>(); m["role"]=history[i].role; m["content"]=history[i].content;
    }
    JsonObject usr = msgs.add<JsonObject>(); usr["role"]="user"; usr["content"]=userText;
    String body; serializeJson(req, body);
    if (!https.begin(client, GROQ_HOST)) { delay(600); continue; }
    https.addHeader("Authorization", String("Bearer ") + GROQ_KEY);
    https.addHeader("Content-Type", "application/json");
    https.addHeader("Connection", "close");
    int code = https.POST(body);
    Serial.printf("[BRAIN] try %d HTTP %d\n", attempt, code);
    if (code == 200) {
      String payload = https.getString(); https.end();
      JsonDocument filter; filter["choices"][0]["message"]["content"] = true;
      JsonDocument doc;
      DeserializationError err = deserializeJson(doc, payload, DeserializationOption::Filter(filter));
      if (err) { Serial.printf("[BRAIN] JSON err: %s\n", err.c_str()); break; }
      answer = doc["choices"][0]["message"]["content"].as<String>();
      break;
    }
    https.end();
    delay(1000 * attempt);
  }
  return answer;
}

// ================= URL ENCODE =================
String urlEncode(const String& s) {
  String o = ""; const char* hex = "0123456789ABCDEF";
  for (size_t i = 0; i < s.length(); i++) {
    uint8_t c = (uint8_t)s[i];
    if ((c>='0'&&c<='9')||(c>='A'&&c<='Z')||(c>='a'&&c<='z')||c=='-'||c=='_'||c=='.'||c=='~') o += (char)c;
    else { o+='%'; o+=hex[c>>4]; o+=hex[c&0x0F]; }
  }
  return o;
}

// ================= SPLIT + PACK =================
int splitSentences(const String& text, String out[], int maxChunks) {
  int n = 0, start = 0, len = text.length(); String cur = "";
  while (start < len) {
    int end = len;
    for (int i = start; i < len; i++) {
      char c = text[i];
      if (c=='.'||c=='?'||c=='!') { end=i+1; break; }
      if ((uint8_t)c==0xE0 && i+2<len && (uint8_t)text[i+1]==0xA5 && (uint8_t)text[i+2]==0xA4) { end=i+3; break; }
    }
    String sent = text.substring(start, end); sent.trim();
    start = end; while (start < len && text[start]==' ') start++;
    if (sent.length()==0) continue;
    if (cur.length()==0) cur = sent;
    else if (cur.length()+sent.length()+1 <= TTS_CHUNK_CHARS) cur += " " + sent;
    else { if (n<maxChunks) out[n++]=cur; cur=sent; }
  }
  if (cur.length()>0 && n<maxChunks) out[n++]=cur;
  return n;
}

// ================= DOWNLOAD ONE CHUNK (hardened, verbose) =================
bool downloadChunk(const String& piece, int idx) {
  // allocate buffer ONCE, up front, with a guard
  if (!chunkBuf[idx]) {
    chunkBuf[idx] = (uint8_t*) ps_malloc(MAX_MP3_BYTES);
    if (!chunkBuf[idx]) { Serial.printf("[DL] %d psram alloc FAIL\n", idx); return false; }
  }

  for (int attempt = 1; attempt <= 3; attempt++) {
    Serial.printf("[DL] %d connecting (try %d)\n", idx, attempt);
    Serial.flush();

    String url = "http://translate.google.com/translate_tts?ie=UTF-8&tl=hi&client=tw-ob&q="
                 + urlEncode(piece);

    WiFiClient client;
    HTTPClient http;
    http.setReuse(false);
    http.setTimeout(8000);
    if (!http.begin(client, url)) { Serial.println("[DL] begin fail"); delay(400); continue; }
    http.addHeader("User-Agent", "Mozilla/5.0");

    int code = http.GET();
    Serial.printf("[DL] %d HTTP %d\n", idx, code);
    if (code != 200) { http.end(); delay(400 * attempt); continue; }

    int total = http.getSize();
    WiFiClient* stream = http.getStreamPtr();
    uint32_t got = 0, lastData = millis();
    uint8_t tmp[1024];

    while (http.connected() && got < MAX_MP3_BYTES) {
      size_t avail = stream->available();
      if (avail) {
        size_t want = avail > sizeof(tmp) ? sizeof(tmp) : avail;
        if (want > MAX_MP3_BYTES - got) want = MAX_MP3_BYTES - got;
        int r = stream->readBytes(tmp, want);
        if (r > 0) { memcpy(chunkBuf[idx] + got, tmp, r); got += r; lastData = millis(); }
      } else {
        if (total > 0 && got >= (uint32_t)total) break;
        if (millis() - lastData > 4000) break;
        vTaskDelay(1);
      }
    }
    http.end();

    if (got > 0) {
      chunkLen[idx] = got;
      Serial.printf("[DL] %d done = %u bytes\n", idx, (unsigned)got);
      return true;
    }
    delay(400 * attempt);
  }
  Serial.printf("[DL] %d FAILED\n", idx);
  return false;
}

// ================= PLAY ONE CHUNK FROM PSRAM =================
void playChunkMem(int idx) {
  if (chunkFailed[idx] || chunkLen[idx] == 0 || !chunkBuf[idx]) return;
  AudioOutputI2S* out = new AudioOutputI2S(1);
  out->SetPinout(AMP_BCLK, AMP_LRCLK, AMP_DIN);
  out->SetOutputModeMono(true);
  out->SetGain(SPK_GAIN);
  AudioFileSourceMem* src = new AudioFileSourceMem(chunkBuf[idx], chunkLen[idx]);
  AudioGeneratorMP3*  mp3 = new AudioGeneratorMP3();
  if (mp3->begin(src, out)) {
    uint32_t guard = millis();
    while (mp3->isRunning()) {
      if (!mp3->loop()) break;
      if (millis() - guard > 15000) break;
      vTaskDelay(1);
    }
    mp3->stop();
  } else {
    Serial.printf("[TTS] begin fail chunk %d\n", idx);
  }
  delete mp3;
  delete src;
  delete out;
}

// ================= SPEAK =================
void speak(const String& text) {
  if (text.length() == 0) return;
  String parts[MAX_CHUNKS];
  int n = splitSentences(text, parts, MAX_CHUNKS);
  chunkCount = n;
  for (int i = 0; i < MAX_CHUNKS; i++) { chunkLen[i] = 0; chunkFailed[i] = false; }
  Serial.printf("[TTS] %d chunk(s)\n", n);
  Serial.flush();

  ledOn();
  for (int i = 0; i < n; i++) {
    Serial.printf("[DL] (%d/%d) start\n", i + 1, n);
    Serial.flush();
    chunkFailed[i] = !downloadChunk(parts[i], i);
  }
  ledOff();

  for (int i = 0; i < n; i++) {
    if (chunkFailed[i] || chunkLen[i] == 0) { Serial.printf("[TTS] skip %d\n", i + 1); continue; }
    Serial.printf("[TTS] play (%d/%d)\n", i + 1, n);
    playChunkMem(i);
    if (i < n - 1) delay(TTS_GAP_MS);
  }
  Serial.println("[TTS] done");
}

// ================= WIFI =================
bool wifiConnect() {
  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  Serial.printf("[WiFi] connecting to \"%s\"...\n", WIFI_SSID);
  uint32_t start = millis();
  while (WiFi.status() != WL_CONNECTED) {
    delay(400);
    Serial.print(".");
    if (millis() - start > WIFI_TIMEOUT_MS) {
      Serial.printf("\n[WiFi] FAILED status=%d - retry next cycle\n", WiFi.status());
      WiFi.disconnect(true);
      return false;
    }
    yield();
  }
  Serial.printf("\n[WiFi] connected RSSI=%d IP=%s\n",
                WiFi.RSSI(), WiFi.localIP().toString().c_str());
  return true;
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  delay(1500);
  Serial.println("\n=== Jarvis Stage 9 (download hardened) ===");
  printResetReason();

  ioInit();

  wavBuf = (uint8_t*) ps_malloc(WAV_BYTES);
  if (!wavBuf) { Serial.println("[FATAL] PSRAM alloc fail"); while (true) delay(1000); }
  if (ESP.getFreePsram() == 0) { Serial.println("[FATAL] PSRAM=0"); while (true) delay(1000); }
  Serial.printf("[MEM] heap=%u PSRAM=%u\n", ESP.getFreeHeap(), ESP.getFreePsram());

  if (!wifiConnect()) Serial.println("[WiFi] not connected at boot; loop retries");

  configTime(0, 0, "pool.ntp.org", "time.nist.gov");
  time_t now = time(nullptr);
  uint32_t ntpStart = millis();
  while (now < 1000000000 && millis() - ntpStart < 15000) { delay(300); now = time(nullptr); }
  Serial.printf("[NTP] %ld\n", (long)now);

  micInit();
  ledOn(); buzz(150); ledOff();

  Serial.println("\n>>> Ready. Ask a question each cycle.");
}

// ================= LOOP =================
void loop() {
  if (WiFi.status() != WL_CONNECTED) {
    if (!wifiConnect()) { delay(3000); return; }
  }
  Serial.printf("[NET] RSSI=%d IP=%s\n", WiFi.RSSI(), WiFi.localIP().toString().c_str());
  Serial.println(">>> recording in 3s");
  delay(3000);

  ledOn();
  buzz(120);
  recordAudio();

  String youSaid = transcribe();
  youSaid.trim();

  if (youSaid.length() == 0) {
    Serial.println("[STT] no transcript");
    ledOff();
  } else {
    Serial.print("YOU SAID: "); Serial.println(youSaid);
    String reply = askGroq(youSaid);
    reply.trim(); reply.replace("\n", " ");
    ledOff();
    if (reply.length() > 0) {
      Serial.print("JARVIS: "); Serial.println(reply);
      pushHistory("user", youSaid);
      pushHistory("assistant", reply);
      buzz(80);
      speak(reply);
    } else {
      Serial.println("[BRAIN] no reply");
    }
  }
  Serial.println(">>> pause 5s");
  delay(5000);
}
