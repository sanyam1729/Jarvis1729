// ================= IN-MEMORY MP3 SOURCE =================
class AudioFileSourceMem : public AudioFileSource {
public:
  AudioFileSourceMem(const uint8_t* data, uint32_t len) : d(data), n(len), p(0) {}
  virtual uint32_t read(void* dst, uint32_t len) override {
    if (!d || p >= n) return 0;
    uint32_t avail = n - p;
    if (len > avail) len = avail;
    memcpy(dst, d + p, len);
    p += len;
    return len;
  }
  virtual bool seek(int32_t pos, int dir) override {
    int32_t np;
    if (dir == SEEK_SET) np = pos;
    else if (dir == SEEK_CUR) np = (int32_t)p + pos;
    else np = (int32_t)n + pos;
    if (np < 0 || (uint32_t)np > n) return false;
    p = (uint32_t)np; return true;
  }
  virtual bool close() override { p = n; return true; }
  virtual bool isOpen() override { return d != nullptr; }
  virtual uint32_t getSize() override { return n; }
  virtual uint32_t getPos() override { return p; }
private:
  const uint8_t* d; uint32_t n; uint32_t p;
};

